# ─── App ─────────────────────────────────────────────
APP_NAME=Vacation Control API
APP_ENV=dev
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://vacation_user:vacation_pass@localhost:5432/vacation_db

# ─── Auth ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── LLM (opcional) ─────────────────────────────────
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
